.DS_Store
.idea
.venv/
.testvenv/
__pycache__/
.pytest_cache/
.mypy_cache/
.ruff_cache/
.coverage
coverage.xml
htmlcov/
*.pyc
# Setuptools metadata regenerated on every ``pip install -e .`` /
# ``python -m build`` -- the contents are derived from
# ``pyproject.toml`` and would otherwise drift between checkouts.
*.egg-info/
build/
dist/
# Generated at build time by ``python -m investing`` (uploaded as the
# GitHub Pages artifact).
index.html
sitemap.xml
robots.txt
og-image.png
# Content-addressable cache sidecar that ``investing.webpage.og_image``
# writes next to the PNG so the next run can short-circuit when the
# headline numbers haven't changed.
og-image.png.sha256
# Local debug renders produced by ``scripts/preview.py``.
preview/
# CI smoke-parse output (HTML smoke test in test.yml).
ci-smoke/
# Staged GitHub Pages artifact (``scripts/stage_site.py``).
site/
